<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .error-container {
            text-align: center;
            padding: 3rem;
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
            border-radius: 8px;
            color: white;
            margin: 2rem 0;
        }
        
        .error-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
        }
        
        .error-details {
            background: rgba(0, 0, 0, 0.2);
            padding: 1rem;
            border-radius: 4px;
            margin: 1rem 0;
            text-align: left;
            overflow-x: auto;
        }
        
        .btn {
            display: inline-block;
            padding: 0.75rem 1.5rem;
            background: white;
            color: #e74c3c;
            text-decoration: none;
            border-radius: 4px;
            margin-top: 1rem;
            transition: transform 0.3s ease;
        }
        
        .btn:hover {
            transform: translateY(-2px);
        }
    </style>
</head>
<body>
    <%- include('layouts/navbar', { activePage: 'home' }) %>
    
    <div class="container">
        <div class="error-container">
            <div class="error-icon">⚠️</div>
            <h1><%= title %></h1>
            <p><%= message %></p>
            <% if (error) { %>
                <div class="error-details">
                    <strong>Error Details:</strong><br>
                    <code><%= error %></code>
                </div>
            <% } %>
            <a href="/" class="btn">Return to Home</a>
        </div>
    </div>
    
    <%- include('layouts/footer') %>
</body>
</html>